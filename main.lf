target Python{
    keepalive: true
}

reactor scale{ 
    timer t(1 sec, 1 sec);
    output weight

    reaction(startup)->weight {=
	    from HX711 import SimpleHX711, Rate
	    self.hx = SimpleHX711(5, 6, 1, 0, Rate.HZ_80)
    =}

    reaction(t)->weight {=
	    print(hx.weight())
    =}
}

main reactor{
    s = new scale()
    print("starting sclae reactor\n")
    print(s.weight)
}

